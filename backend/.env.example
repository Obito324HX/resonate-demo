# Copy this file to .env and fill in real values. Never commit .env itself.

# Neon connection string — get this from your Neon project dashboard.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/resonate?sslmode=require"

# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-secret"

PORT=4000
